[Unit]
Description=HomeKit Desktop Power Switch
After=network.target avahi-daemon.service
Wants=avahi-daemon.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /userapp/homekit-switch/homekit_daemon.py
WorkingDirectory=/userapp/homekit-switch
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=homekit-switch

[Install]
WantedBy=multi-user.target
